# ============================================
#  SISTEMA PRO CUIDADOR — Tracking & Atribución
#  Copia este archivo como .env.local (local)
#  o pega estas variables en Vercel → Settings → Environment Variables
# ============================================

# --- META ---
# Tu Pixel ID (público, ya configurado)
NEXT_PUBLIC_META_PIXEL_ID=954054883661119

# Access Token de la Conversions API.
# Events Manager → tu Pixel → Configuración → Conversions API → Generar token de acceso
# ⚠️ SECRETO. Nunca lo pongas en el frontend ni lo subas a GitHub.
META_CAPI_ACCESS_TOKEN=

# Código de prueba (opcional, solo para depurar en Events Manager → Probar eventos).
# Déjalo VACÍO en producción o los eventos no contarán como reales.
META_TEST_EVENT_CODE=

# Versión de la Graph API (v25.0 es la vigente en julio 2026)
META_GRAPH_VERSION=v25.0

# --- HOTMART ---
# Hottok de verificación: Hotmart → Herramientas → Webhook (API y Notificaciones)
# ⚠️ SECRETO.
HOTMART_HOTTOK=

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ SECRETO. Solo backend. Permite escribir saltando RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- DASHBOARD ---
# Contraseña para entrar al AdsBoard (/). Ponle una que solo sepas tú.
DASHBOARD_PASSWORD=cambiame

# --- CORS ---
# Dominios de tus landings separados por coma, para que puedan enviar eventos.
# Ej: https://sistemaprocuidador.com,https://www.sistemaprocuidador.com
ALLOWED_ORIGINS=*
